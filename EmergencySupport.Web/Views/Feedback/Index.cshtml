@model List<EmergencySupport.Entities.Feedback>

@Html.Partial("_Message")

<div class="row pt-4">

    <div class="col-6">
        <h2>Feedback</h2>
    </div>

    <div class="col-6 text-end">
        @if (User.IsInRole("user"))
        {
            <a class="btn btn-primary"
               asp-action="Create"
               asp-route-dataId="-1">

                <i class="bi bi-plus-lg"></i> &nbsp; Add Feedback
            </a>
        }
    </div>

    <hr />
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Ref</th>
            <th>Emergency Request</th>
            <th>User</th>
            <th>Rating</th>
            <th>Comments</th>
            @if (User.IsInRole("user"))
            {
                <th style="width:250px">Actions</th>
            }
        </tr>
    </thead>

    <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="7"
                    class="text-center">
                    No Data To Show
                </td>
            </tr>
        }
        else
        {
            @foreach (var feedback in Model)
            {
                <tr>
                    <td>@feedback.FeedbackId</td>
                    <td>@feedback.Request.EmergencyType</td>
                    <td>@feedback.User.Name</td>
                    <td>@feedback.Rating</td>
                    <td>@feedback.Comments</td>
                    @if (User.IsInRole("user"))
                    {
                        <td>

                            <a asp-action="Create" asp-route-dataId="@feedback.FeedbackId" class="btn btn-success">
                                <i class="bi bi-pencil-square"></i> &nbsp; Edit
                            </a>

                            <a asp-action="Delete" asp-route-dataId="@feedback.FeedbackId" class="btn btn-danger" onclick="return confirm('Are you sure?')">
                                <i class="bi bi-trash"></i> &nbsp; Delete
                            </a>

                        </td>
                    }
                </tr>
            }
        }
    </tbody>
</table>