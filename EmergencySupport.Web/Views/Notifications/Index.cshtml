@model List<EmergencySupport.Entities.Notifications>

@Html.Partial("_Message")

<div class="row pt-4">

    <div class="col-6">
        <h2>Emergency Notifications</h2>
    </div>

    <div class="col-6 text-end">

        <a class="btn btn-primary"
           asp-action="Create"
           asp-route-dataId="-1">

            <i class="bi bi-plus-lg"></i> &nbsp; Add Notification
        </a>

    </div>

    <hr />
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Message</th>
            <th>Type</th>

            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="8"
                    class="text-center">
                    No Data To Show
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.NotificationId</td>
                    <td>@item.Message</td>
                    <td>@item.Type</td>
                    <td>


                        <a asp-action="Create" asp-route-dataId="@item.NotificationId" class="btn btn-success btn-sm">
                            <i class="bi bi-pencil-square"></i> &nbsp; Edit
                        </a>



                        <a asp-action="Delete" asp-route-dataId="@item.NotificationId" class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure?')">
                            <i class="bi bi-trash"></i> &nbsp; Delete
                        </a>

                    </td>
                </tr>
            }
        }
    </tbody>
</table>