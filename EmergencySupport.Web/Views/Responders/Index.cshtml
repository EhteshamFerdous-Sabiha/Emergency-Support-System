@model List<EmergencySupport.Entities.Responders>

@Html.Partial("_Message")

<div class="row pt-4">

    <div class="col-6">
        <h2>Responders</h2>
    </div>

    <div class="col-6 text-end">

        <a class="btn btn-primary"
           asp-action="Create"
           asp-route-dataId="-1">

            <i class="bi bi-plus-lg"></i>
            &nbsp; Add Responder

        </a>

    </div>

    <hr />
</div>

<table class="table table-bordered table-hover">

    <thead class="table-dark">

        <tr>

            <th>ID</th>
            <th>Name</th>
            <th>Service Type</th>
            <th>Availability</th>
            <th>Phone</th>
            <th>Actions</th>

        </tr>

    </thead>

    <tbody>

        @if (Model.Count == 0)
        {
            <tr>

                <td colspan="6"
                    class="text-center">

                    No Data

                </td>

            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>

                    <td>@item.ResponderId</td>

                    <td>@item.User?.Name</td>

                    <td>@item.ServiceType</td>

                    <td>@item.AvailabilityStatus</td>

                    <td>@item.User?.Phone</td>

                    <td>

                        <a asp-action="Create"
                           asp-route-dataId="@item.ResponderId"
                           class="btn btn-success">

                            <i class="bi bi-pencil-square"></i>
                            &nbsp; Edit

                        </a>

                        <a asp-action="Delete"
                           asp-route-dataId="@item.ResponderId"
                           class="btn btn-danger"
                           onclick="return confirm('Are you sure?')">

                            <i class="bi bi-trash"></i>
                            &nbsp; Delete

                        </a>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>